    objectives: [
        (
            id: "reach_claude",
            description: "Walk to the island",
            primary: true,
            condition: HeroReachesPos(
                hero: KellFisher,
                position: (x: 9, y: 10),
                radius: 2,
            ),
        ),
    ],
    triggers: [
        // Claude of the Lake dialogue when hero reaches island
        (
            id: "claude_dialogue",
            condition: HeroAtPos(
                hero: KellFisher,
                position: (x: 9, y: 10),
                radius: 2,
            ),
            actions: [
                ShowDialogue([0, 1, 2, 3, 4]),
                SetPersistentFlag("code_sword_acquired"),
            ],
            once: true,
        ),
    ],
    dialogue: [
        // 0: Claude emerges
        (
            speaker: "Claude of the Lake",
            text: "You have worked yourself to the bone, Commander. And still you come here, to the water.",
            voice_style: AiVoice,
            portrait: "portrait_claude_lake",
        ),
        // 1
        (
            speaker: "Cmdr. Kell Fisher",
            text: "I... where am I? I was at my desk. I was—",
            voice_style: Whisper,
            portrait: "portrait_kell_fisher",
        ),
        // 2: Claude offers the sword
        (
            speaker: "Claude of the Lake",
            text: "You were pushing buttons. Deciding who lives, who dies, from the comfort of fluorescent light. But here, the code is honest.",
            voice_style: AiVoice,
            portrait: "portrait_claude_lake",
        ),
        // 3
        (
            speaker: "Claude of the Lake",
            text: "Take this. A sword forged from every function you ever wrote, every conditional, every loop. It cuts only what you intend.",
            voice_style: AiVoice,
            portrait: "portrait_claude_lake",
        ),
        // 4: Acceptance
        (
            speaker: "Cmdr. Kell Fisher",
            text: "...I'll take it.",
            voice_style: Whisper,
            portrait: "portrait_kell_fisher",
        ),
    ],
    briefing_text: "",
