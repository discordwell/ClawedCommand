// Act 3, Mission 13: Escape from Parliament
// Seekers attack Murder territory. Escape south to LLAMA border.
// Mutators: LavaRise (from east, representing Seekers artillery burning crow's nests),
//           SpeedMultiplier (player faster to emphasize escape urgency).
(
    id: "act3_m13_escape_parliament",
    name: "Escape from Parliament",
    act: 3,
    mission_index: 13,
    map: Generated(
        seed: 3013,
