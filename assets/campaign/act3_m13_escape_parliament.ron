    objectives: [
        (
            id: "reach_llama_border",
            description: "Escape south to the LLAMA border",
            primary: true,
            condition: HeroReachesPos(hero: Kelpie, position: (x: 24, y: 5), radius: 3),
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
    ],
    triggers: [
        // T0: Opening — Parliament is burning
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2])],
            once: true,
        ),
        // T1: Lava begins — Seekers artillery
        (
            id: "lava_warning",
            condition: AtTick(40),
            actions: [ShowDialogue([3, 4])],
            once: true,
        ),
        // T2: Seekers flank wave incoming
        (
            id: "flank_warning",
            condition: AtTick(110),
            actions: [ShowDialogue([5])],
            once: true,
        ),
        // T3: Jinx guides the escape route
        (
            id: "jinx_guidance",
            condition: HeroAtPos(hero: Kelpie, position: (x: 24, y: 35), radius: 8),
            actions: [ShowDialogue([6, 7])],
            once: true,
        ),
        // T4: Deepseek speaks — Mother Granite's judgment
        (
            id: "deepseek_judgment",
            condition: AtTick(250),
            actions: [ShowDialogue([8])],
            once: true,
        ),
        // T5: Near the border — final push
        (
            id: "near_border",
            condition: HeroAtPos(hero: Kelpie, position: (x: 24, y: 12), radius: 8),
            actions: [ShowDialogue([9, 10])],
            once: true,
        ),
        // T6: Escape complete
        (
            id: "escape_complete",
            condition: HeroAtPos(hero: Kelpie, position: (x: 24, y: 5), radius: 3),
            actions: [ShowDialogue([11])],
            once: true,
        ),
    ],
    dialogue: [
        // 0-2: Opening — Parliament burns
        (speaker: "Gemineye", text: "The Seekers have breached Parliament's eastern wall. Ironhide assault groups with Cragback artillery support. The crow's nests are burning.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Which way out?", voice_style: Normal, portrait: ""),
        (speaker: "Jinx", text: "South. Through the ravine. It's narrow and full of things that want to kill us, but at least the Seekers have to squeeze through single file. Come ON.", voice_style: Shout, portrait: ""),

        // 3-4: Lava/fire advancing
        (speaker: "Gemineye", text: "Seekers artillery is creating a fire line from the east. It will advance. Do not be behind it.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Everyone move. Stay ahead of the fire. FlyingFox, screen our retreat.", voice_style: Shout, portrait: ""),

        // 5: Flank warning
        (speaker: "Gemineye", text: "Seekers flanking force detected to the southeast. They are attempting to cut the southern escape route.", voice_style: AiVoice, portrait: ""),

        // 6-7: Jinx guides
        (speaker: "Jinx", text: "Left through the old nesting ground. There's a gap in the canopy the Seekers don't know about. I used to use it for my heists.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "A thief's escape route. At this point, I'll take it.", voice_style: Normal, portrait: ""),

        // 8: Deepseek judgment
        (speaker: "Deepseek", text: "The otter cannot be allowed to reach The Cloud.", voice_style: AiVoice, portrait: ""),

        // 9-10: Near border — final push
        (speaker: "Jinx", text: "I can see the border! LLAMA territory is just past those scrap heaps. One more push!", voice_style: Shout, portrait: ""),
        (speaker: "Kelpie", text: "Nuisances, screen the rear. Hissers, suppress the blockade. FlyingFox, get over that wall. We are leaving NOW.", voice_style: Shout, portrait: ""),

        // 11: Escape complete
        (speaker: "Kelpie", text: "We're across. The Seekers won't follow into LLAMA territory. Not yet. We need to find King Ringtail before they change their minds.", voice_style: Normal, portrait: ""),
    ],
    briefing_text: "The Seekers of the Deep have attacked Murder Parliament. Mother Granite has decided the otter is too dangerous to leave uncontrolled. Escape south through burning crow's nests to the LLAMA border. The fire advances from the east. Stay ahead of it.",
    debrief_text: "Parliament burns behind them. Mother Granite's silhouette stands against the fire, Deepseek's voice rolling like thunder. Kelpie crosses into LLAMA territory carrying a fragment of their former self and the weight of a choice that echoes across every AI channel.",
    next_mission: Fixed("act4_m14_junkyard_fort"),
    mutators: [
        LavaRise(
            interval_ticks: 40,
            damage_per_tick: 8,
            direction: East,
            rows_per_wave: 2,
            initial_delay_ticks: 50,
        ),
        SpeedMultiplier(
            player_multiplier: (bits: 78643),
            enemy_multiplier: (bits: 65536),
        ),
    ],
)
