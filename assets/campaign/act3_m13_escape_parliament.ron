                (kind: Hisser, position: (x: 42, y: 52), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 50)),
        ),
        // Wave 2: Seekers flanking force — cutting off the southern route
        (
            wave_id: "seekers_flank",
            trigger: AtTick(120),
