    dialogue: [
        // 0-5: Opening — Granite's confrontation and Ironjaw's defiance
        (speaker: "Mother Granite", text: "You spoke to the Corvus Rex. Deepseek heard the entire conversation. There is nothing in my territory that does not echo.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "What is buried under the Sett, Granite?", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "You are no longer welcome here.", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "Wardenmother. My oath to protect the envoy has not expired.", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "Stand down, Ironjaw.", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "No.", voice_style: Normal, portrait: ""),

        // 6-7: Tunnel entry
        (speaker: "Ironjaw", text: "I helped build these tunnels. I know every passage, every patrol route, every blind spot. Stay close. Stay quiet.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "She will strip your rank for this.", voice_style: Normal, portrait: ""),

        // 8-9: First patrol
        (speaker: "Ironjaw", text: "Patrol ahead. Two Chonks and a Hisser. They cycle every forty ticks. Wait for the gap.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "The Mousers can slip past on the left side. The fog will cover us.", voice_style: Normal, portrait: ""),

        // 10-11: Past south gate
        (speaker: "Ironjaw", text: "Good. Through the first gate. Do not relax. The checkpoint ahead is manned permanently.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "How many?", voice_style: Normal, portrait: ""),

        // 12-13: Mid checkpoint
        (speaker: "Ironjaw", text: "Five. Two Chonks at the flanks, Hisser center, Nuisances roving. There is a drainage shaft on the west wall. Tight, but passable for an otter.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "And a badger in an exosuit?", voice_style: Normal, portrait: ""),

        // 14-15: Side passage
        (speaker: "Ironjaw", text: "I am not coming through with you. I am drawing them east. When you hear the alarm, move west. Fast.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Ironjaw, that is not the plan.", voice_style: Normal, portrait: ""),

        // 16-17: Tunnel patrol zone
        (speaker: "Ironjaw", text: "Moving patrol in the connector tunnels. Three units. They loop between the pillars. Time your crossing when they swing east.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "I see them. Mousers first. We go on my signal.", voice_style: Normal, portrait: ""),

        // 18-20: Approaching exit
        (speaker: "Ironjaw", text: "The northern exit. Five guards. This is the last obstacle. They patrol in a wide loop.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Too many to slip past cleanly. Can we draw them off?", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "I told you. I am the distraction. When I engage from the east, run north. Do not stop. Do not look back.", voice_style: Normal, portrait: ""),

        // 21-25: Exit reached — Ironjaw stays behind
        (speaker: "Kelpie", text: "I am through. Ironjaw. Come on.", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "I told you. I do not retreat. I do not break oaths. And I do not disobey the Wardenmother.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "You are disobeying her right now.", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "Yes. I am. Go, otter. Whatever you are, whatever the Rex told you — find out if it is true. That is worth one oath.", voice_style: Normal, portrait: ""),
        (speaker: "Patches", text: "I saw everything. Felix needs to hear this. Also, are you okay?", voice_style: Normal, portrait: ""),
    ],
    briefing_text: "Escape Seekers territory through the tunnel network. Ironjaw guides your small team past patrols and checkpoints. Stealth is survival — your force cannot win a direct fight.",
    debrief_text: "Kelpie escapes into the borderlands. Ironjaw stays behind, arrested for insubordination. Patches steps out of the shadows at the border. The Rex's words echo: when you are ready to learn what you are, come find me.",
    ai_tool_tier: None,
    next_mission: Fixed("act3_m9_jinx"),
    mutators: [
        DenseFog(
            vision_reduction: 6,
            periodic_clearing: None,
        ),
        RestrictedUnits(
            allowed_kinds: [Mouser, Nuisance],
            max_unit_count: Some(6),
        ),
        NoBuildMode,
        NoAiControl,
    ],
)
