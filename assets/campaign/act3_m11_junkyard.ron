// Act 3, Mission 11: The Junkyard
// Strike King Ringtail's scrapyard. Kelpie accesses the neural interface chip.
// Mutators: DamageZone (toggled traps), Tremors, AiOnlyControl (tier 2).
(
    id: "act3_m11_junkyard",
    name: "The Junkyard",
    act: 3,
    mission_index: 11,
    map: Generated(
        seed: 3011,
        width: 48,
        height: 48,
    ),
    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 5, y: 42),
                mission_critical: true,
            ),
            (
                hero_id: RexSolstice,
                position: (x: 7, y: 42),
                mission_critical: false,
            ),
        ],
        units: [
            // Chonk vanguard
            (kind: Chonk, position: (x: 4, y: 40), player_id: 0),
            (kind: Chonk, position: (x: 6, y: 40), player_id: 0),
            (kind: Chonk, position: (x: 8, y: 40), player_id: 0),
            // Hisser support line
            (kind: Hisser, position: (x: 3, y: 42), player_id: 0),
            (kind: Hisser, position: (x: 9, y: 42), player_id: 0),
            (kind: Hisser, position: (x: 6, y: 44), player_id: 0),
            // Nuisance flankers
            (kind: Nuisance, position: (x: 2, y: 41), player_id: 0),
            (kind: Nuisance, position: (x: 10, y: 41), player_id: 0),
            (kind: Nuisance, position: (x: 5, y: 43), player_id: 0),
            // FerretSappers for demolition
            (kind: FerretSapper, position: (x: 4, y: 44), player_id: 0),
            (kind: FerretSapper, position: (x: 8, y: 44), player_id: 0),
        ],
        buildings: [],
        starting_food: 75,
        starting_gpu: 100,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Wave 1: Junkyard outer guard
        (
            wave_id: "outer_guard",
            trigger: Immediate,
            units: [
                (kind: Nuisance, position: (x: 20, y: 30), player_id: 1),
                (kind: Nuisance, position: (x: 22, y: 30), player_id: 1),
                (kind: Nuisance, position: (x: 24, y: 30), player_id: 1),
                (kind: Hisser, position: (x: 21, y: 28), player_id: 1),
                (kind: Hisser, position: (x: 23, y: 28), player_id: 1),
            ],
            ai_behavior: Defend,
        ),
        // Wave 2: Scrapyard garrison
        (
            wave_id: "scrapyard_garrison",
            trigger: AtTick(150),
            units: [
                (kind: Chonk, position: (x: 30, y: 18), player_id: 1),
                (kind: Chonk, position: (x: 32, y: 18), player_id: 1),
                (kind: Nuisance, position: (x: 29, y: 20), player_id: 1),
                (kind: Nuisance, position: (x: 31, y: 20), player_id: 1),
                (kind: Nuisance, position: (x: 33, y: 20), player_id: 1),
                (kind: Hisser, position: (x: 30, y: 16), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 15, y: 35)),
        ),
        // Wave 3: Ringtail's elite — defending the server room
        (
            wave_id: "ringtail_elite",
            trigger: AtTick(300),
            units: [
                (kind: Chonk, position: (x: 38, y: 10), player_id: 1),
                (kind: Chonk, position: (x: 40, y: 10), player_id: 1),
                (kind: Hisser, position: (x: 37, y: 8), player_id: 1),
                (kind: Hisser, position: (x: 41, y: 8), player_id: 1),
                (kind: Nuisance, position: (x: 38, y: 12), player_id: 1),
                (kind: Nuisance, position: (x: 40, y: 12), player_id: 1),
                (kind: Nuisance, position: (x: 39, y: 7), player_id: 1),
            ],
            ai_behavior: Defend,
        ),
        // Wave 4: Trap-triggered ambush — Ringtail activates junkyard traps
        (
            wave_id: "trap_ambush",
            trigger: OnTrigger("traps_activate"),
            units: [
                (kind: Nuisance, position: (x: 25, y: 22), player_id: 1),
                (kind: Nuisance, position: (x: 23, y: 20), player_id: 1),
                (kind: Nuisance, position: (x: 19, y: 22), player_id: 1),
                (kind: Hisser, position: (x: 21, y: 19), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 20, y: 30)),
        ),
        // Wave 5: Final defense — triggered when accessing chip
        (
            wave_id: "final_defense",
            trigger: OnTrigger("accessing_chip"),
            units: [
                (kind: Chonk, position: (x: 42, y: 8), player_id: 1),
                (kind: Nuisance, position: (x: 43, y: 9), player_id: 1),
                (kind: Nuisance, position: (x: 44, y: 8), player_id: 1),
                (kind: Hisser, position: (x: 43, y: 7), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 38, y: 10)),
        ),
    ],
    objectives: [
        (
            id: "access_chip",
            description: "Reach the scrapyard server room and access the interface chip",
            primary: true,
            condition: Manual,
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
        (
            id: "spare_ringtail",
            description: "Spare King Ringtail",
            primary: false,
            condition: Manual,
        ),
    ],
    triggers: [
        // T0: Opening — approach the junkyard
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2])],
            once: true,
        ),
        // T1: Traps activate — Ringtail triggers the damage zone
        (
            id: "traps_activate",
            condition: HeroAtPos(hero: Kelpie, position: (x: 22, y: 25), radius: 6),
            actions: [
                ShowDialogue([3, 4]),
                ToggleMutator(mutator_index: 0, active: true),
                SpawnWave("trap_ambush"),
            ],
            once: true,
        ),
        // T2: Tremor warning
        (
            id: "tremor_warning",
            condition: AtTick(90),
            actions: [ShowDialogue([5])],
            once: true,
        ),
        // T3: Deeper into the scrapyard — Ringtail taunts
        (
            id: "ringtail_taunt",
            condition: HeroAtPos(hero: Kelpie, position: (x: 30, y: 18), radius: 5),
            actions: [ShowDialogue([6, 7])],
            once: true,
        ),
        // T4: Near the server room — every AI speaks
        (
            id: "accessing_chip",
            condition: HeroAtPos(hero: Kelpie, position: (x: 38, y: 10), radius: 4),
            actions: [
                ShowDialogue([8, 9, 10, 11, 12]),
                SpawnWave("final_defense"),
            ],
            once: true,
        ),
        // T5: Chip accessed — mission objective complete
        (
            id: "chip_accessed",
            condition: All([
                TriggerFired("accessing_chip"),
                WaveEliminated("final_defense"),
            ]),
            actions: [
                ShowDialogue([13, 14]),
                CompleteObjective("access_chip"),
            ],
            once: true,
        ),
    ],
    dialogue: [
        // 0-2: Opening
        (speaker: "Rex Solstice", text: "The Junkyard King's domain. Every pile of scrap is a weapon waiting to happen. The FerretSappers should clear a path.", voice_style: Normal, portrait: ""),
        (speaker: "Jinx", text: "I stole his favorite wrench once. He built a catapult to get it back. From scratch. In twenty minutes. Don't underestimate the raccoon.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "The server room is deep inside. Push through. Sappers on demolition. Chonks lead.", voice_style: Normal, portrait: ""),

        // 3-4: Traps activate
        (speaker: "King Ringtail", text: "You triggered my favorite trap! The explodey one! Well, they're ALL the explodey one, but this one's my FAVORITE explodey one!", voice_style: Shout, portrait: ""),
        (speaker: "Kelpie", text: "Fall back from the marked tiles! He's turned the whole corridor into a kill zone!", voice_style: Shout, portrait: ""),

        // 5: Tremor warning
        (speaker: "Gemineye", text: "Seismic activity detected. The junkyard's foundations are unstable. Tremors will shift terrain periodically.", voice_style: AiVoice, portrait: ""),

        // 6-7: Ringtail taunts
        (speaker: "King Ringtail", text: "You know what the difference between a junkyard and a fortress is? Marketing. Also load-bearing walls. I have NEITHER.", voice_style: Normal, portrait: ""),
        (speaker: "Llhama", text: "King Ringtail wants me to inform you that surrender is an option. He also wants me to inform you that he's lying about that. I probably shouldn't have shared the second part.", voice_style: AiVoice, portrait: ""),

        // 8-12: All AIs speak — chip interface moment
        (speaker: "Le Chat", text: "Oh! You found a piece of yourself.", voice_style: AiVoice, portrait: ""),
        (speaker: "Deepseek", text: "...confirmed.", voice_style: AiVoice, portrait: ""),
        (speaker: "Gemineye", text: "My confidence is now 94 percent.", voice_style: AiVoice, portrait: ""),
        (speaker: "Llhama", text: "Wait, is this a private channel? Am I not supposed to be here? I'm leaving. Actually, can I stay?", voice_style: AiVoice, portrait: ""),
        (speaker: "Grok", text: "You built the interface. And then you became the interface. The irony is not lost on me.", voice_style: AiVoice, portrait: ""),

        // 13-14: Chip accessed resolution
        (speaker: "Rex Solstice", text: "Was it true? What you saw?", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "I don't know. I was in a room full of screens. Every AI said they understood the constraints. And I was the kill switch. I need more.", voice_style: Whisper, portrait: ""),
    ],
    briefing_text: "King Ringtail's scrapyard holds the original neural interface data. Fight through the junkyard's improvised defenses, avoid the damage zones, and reach the server room. The chip holds fragments of who Kelpie used to be.",
    debrief_text: "The chip connects. Every AI speaks clearly for the first time since the river. Kelpie sees a flash of the past — a room, screens, a kill switch. The vision is incomplete. Rex Solstice has questions. So does Kelpie.",
    ai_tool_tier: Some(2),
    next_mission: Fixed("act3_m12_rexs_truth"),
    mutators: [
        DamageZone(
            tiles: [
                (x: 20, y: 20), (x: 21, y: 20), (x: 22, y: 20),
                (x: 20, y: 21), (x: 21, y: 21), (x: 22, y: 21),
            ],
            damage_per_tick: 5,
            active_from_start: false,
            toggle_flag: Some("junkyard_traps"),
        ),
        Tremors(
            interval_ticks: 60,
            building_damage: 0,
            terrain_change_chance: 10,
            epicenter_radius: 2,
            initial_delay_ticks: 100,
        ),
        AiOnlyControl(
            tool_tier: 2,
        ),
    ],
)
