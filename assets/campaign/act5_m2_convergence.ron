            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 7: Murder + LLAMA surprise — south (Ringtail's wrong-leak forces)
        (
            wave_id: "wave7_south_surprise",
            trigger: OnTrigger("spawn_south_surprise"),
            units: [
                (kind: Nuisance, position: (x: 28, y: 58), player_id: 4),
                (kind: Nuisance, position: (x: 30, y: 59), player_id: 4),
                (kind: Hisser, position: (x: 32, y: 58), player_id: 2),
                (kind: Chonk, position: (x: 34, y: 59), player_id: 2),
                (kind: FlyingFox, position: (x: 29, y: 60), player_id: 4),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 8: Final all-faction push — everything left
        (
            wave_id: "wave8_final_push",
            trigger: OnTrigger("spawn_final_push"),
            units: [
