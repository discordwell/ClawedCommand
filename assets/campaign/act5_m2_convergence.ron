                (kind: Chonk, position: (x: 30, y: 60), player_id: 4),
                (kind: Hisser, position: (x: 32, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 4, y: 32), player_id: 2),
                (kind: Hisser, position: (x: 60, y: 32), player_id: 3),
                (kind: Hisser, position: (x: 32, y: 60), player_id: 4),
