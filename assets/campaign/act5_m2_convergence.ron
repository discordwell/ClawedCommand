            units: [
                (kind: Chonk, position: (x: 28, y: 3), player_id: 1),
                (kind: Chonk, position: (x: 32, y: 3), player_id: 1),
                (kind: Hisser, position: (x: 30, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 34, y: 2), player_id: 1),
                (kind: Nuisance, position: (x: 29, y: 4), player_id: 1),
                (kind: Nuisance, position: (x: 33, y: 4), player_id: 1),
                (kind: Yowler, position: (x: 31, y: 2), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 6: Clawed second wave + Seekers reinforcement — pincer
        (
            wave_id: "wave6_pincer",
            trigger: OnTrigger("spawn_pincer"),
            units: [
                (kind: Nuisance, position: (x: 5, y: 34), player_id: 2),
                (kind: Nuisance, position: (x: 4, y: 36), player_id: 2),
                (kind: Chonk, position: (x: 3, y: 35), player_id: 2),
