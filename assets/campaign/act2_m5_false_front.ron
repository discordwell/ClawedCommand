    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 24, y: 40),
                mission_critical: true,
            ),
            (
                hero_id: MotherGranite,
                position: (x: 26, y: 40),
                mission_critical: false,
            ),
        ],
        units: [
            // Seekers-style heavy defense — Chonk wall with Hisser support
            (kind: Chonk, position: (x: 22, y: 38), player_id: 0),
            (kind: Chonk, position: (x: 24, y: 38), player_id: 0),
            (kind: Chonk, position: (x: 26, y: 38), player_id: 0),
            (kind: Chonk, position: (x: 28, y: 38), player_id: 0),
            (kind: Hisser, position: (x: 22, y: 40), player_id: 0),
            (kind: Hisser, position: (x: 23, y: 41), player_id: 0),
            (kind: Hisser, position: (x: 27, y: 41), player_id: 0),
            (kind: Hisser, position: (x: 28, y: 40), player_id: 0),
            (kind: Nuisance, position: (x: 20, y: 39), player_id: 0),
            (kind: Nuisance, position: (x: 30, y: 39), player_id: 0),
        ],
        buildings: [],
        starting_food: 200,
        starting_gpu: 75,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Wave 1: Murder scouts probing from the north — phantom-style feint
        (
            wave_id: "wave1_scouts",
            trigger: AtTick(30),
            units: [
                (kind: Nuisance, position: (x: 22, y: 5), player_id: 1),
                (kind: Nuisance, position: (x: 24, y: 4), player_id: 1),
                (kind: Nuisance, position: (x: 26, y: 5), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 40)),
        ),
        // Wave 2: Flanking force — arrives from the east
        (
            wave_id: "wave2_flank",
            trigger: AtTick(150),
            units: [
                (kind: Nuisance, position: (x: 44, y: 20), player_id: 1),
                (kind: Nuisance, position: (x: 45, y: 21), player_id: 1),
                (kind: Hisser, position: (x: 44, y: 22), player_id: 1),
                (kind: Hisser, position: (x: 45, y: 19), player_id: 1),
                (kind: Chonk, position: (x: 46, y: 20), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 40)),
        ),
        // Wave 3: Main assault from the north — larger force
        (
            wave_id: "wave3_main",
            trigger: AtTick(300),
            units: [
                (kind: Nuisance, position: (x: 20, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 22, y: 4), player_id: 1),
                (kind: Nuisance, position: (x: 24, y: 3), player_id: 1),
                (kind: Hisser, position: (x: 21, y: 5), player_id: 1),
                (kind: Hisser, position: (x: 25, y: 5), player_id: 1),
                (kind: Chonk, position: (x: 23, y: 2), player_id: 1),
                (kind: Chonk, position: (x: 26, y: 4), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 40)),
        ),
        // Wave 4: Rear assault — the real trick, hits from behind
        (
            wave_id: "wave4_rear",
            trigger: OnTrigger("spawn_rear_assault"),
            units: [
                (kind: Nuisance, position: (x: 22, y: 46), player_id: 1),
                (kind: Nuisance, position: (x: 24, y: 47), player_id: 1),
                (kind: Nuisance, position: (x: 26, y: 46), player_id: 1),
                (kind: Hisser, position: (x: 23, y: 47), player_id: 1),
                (kind: Hisser, position: (x: 25, y: 47), player_id: 1),
                (kind: Chonk, position: (x: 24, y: 46), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 40)),
        ),
    ],
    objectives: [
        (
            id: "defend_core_tap",
            description: "Defend the Core Tap for 500 ticks",
            primary: true,
            condition: Survive(500),
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
        (
            id: "eliminate_flankers",
            description: "Eliminate the rear assault force",
            primary: false,
            condition: EliminateWave("wave4_rear"),
        ),
    ],
    triggers: [
        // T0: Opening — Granite briefs the defense
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2, 3, 4])],
            once: true,
        ),
        // T1: Fog rolls in
        (
            id: "fog_rolls_in",
            condition: AtTick(20),
            actions: [ShowDialogue([5, 6])],
            once: true,
        ),
        // T2: Scouts spotted
        (
            id: "scouts_spotted",
            condition: AtTick(30),
            actions: [ShowDialogue([7, 8])],
            once: true,
        ),
        // T3: First blood
        (
            id: "first_blood",
            condition: EnemyKillCount(2),
            actions: [ShowDialogue([9])],
            once: true,
        ),
        // T4: Flank wave warning
        (
            id: "flank_warning",
            condition: AtTick(140),
            actions: [ShowDialogue([10, 11])],
            once: true,
        ),
        // T5: Main assault approaching
        (
            id: "main_assault_warning",
            condition: AtTick(280),
            actions: [ShowDialogue([12, 13])],
            once: true,
        ),
        // T6: Rear assault spawns — the real trap
        (
            id: "spawn_rear_assault",
            condition: AtTick(380),
            actions: [
                ShowDialogue([14, 15, 16]),
                SpawnWave("wave4_rear"),
                SetFlag("rear_assault_active"),
            ],
            once: true,
        ),
        // T7: Surviving the rear assault
        (
            id: "rear_cleared",
            condition: WaveEliminated("wave4_rear"),
            actions: [
                ShowDialogue([17]),
                CompleteObjective("eliminate_flankers"),
            ],
            once: true,
        ),
        // T8: Time running low
        (
            id: "time_warning",
            condition: AtTick(450),
            actions: [ShowDialogue([18])],
            once: true,
        ),
        // T9: Defense complete — survived 500 ticks
        (
            id: "defense_complete",
            condition: AtTick(500),
            actions: [
                ShowDialogue([19, 20, 21]),
                CompleteObjective("defend_core_tap"),
            ],
            once: true,
        ),
    ],
    dialogue: [
        // 0-4: Opening — Granite briefs defense
        (speaker: "Mother Granite", text: "The Murder has been flooding our detection grid with phantom contacts for weeks. Deepseek cannot distinguish fabrication from fact quickly enough.", voice_style: Normal, portrait: ""),
        (speaker: "Deepseek", text: "...processing.", voice_style: AiVoice, portrait: ""),
        (speaker: "Mother Granite", text: "That is precisely the problem.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Where do you need me?", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "At the Core Tap. Ironjaw guards the perimeter. You guard what he cannot see. The fog will be thick tonight.", voice_style: Normal, portrait: ""),

        // 5-6: Fog rolls in
        (speaker: "Deepseek", text: "...visibility compromised. Fog density exceeds sensor thresholds.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "I can hear Gemineye's channel. Faint. It is broadcasting phantom positions across the whole northern ridge.", voice_style: Normal, portrait: ""),

        // 7-8: Scouts spotted
        (speaker: "Ironjaw", text: "Contacts north. Three small signatures.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Those are real. The phantoms don't move like that. Chonks forward.", voice_style: Normal, portrait: ""),

        // 9: First blood
        (speaker: "Kelpie", text: "Scouts down. But they were too easy. That was a test.", voice_style: Normal, portrait: ""),

        // 10-11: Flank warning
        (speaker: "Deepseek", text: "...eastern contacts. Confidence: uncertain.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Those are real too. Gemineye is mixing real units with the phantoms. Swing Hissers east.", voice_style: Normal, portrait: ""),

        // 12-13: Main assault approaching
        (speaker: "Mother Granite", text: "The northern signatures are multiplying. Deepseek?", voice_style: Normal, portrait: ""),
        (speaker: "Deepseek", text: "...seventy percent fabrication. Thirty percent lethal. Insufficient data for further refinement.", voice_style: AiVoice, portrait: ""),

        // 14-16: Rear assault — the real trap
        (speaker: "Kelpie", text: "Wait. Gemineye just went silent on one channel. Completely silent. That is not how fabrication works.", voice_style: Normal, portrait: ""),
        (speaker: "Ironjaw", text: "BEHIND US! South approach! Six heavy contacts!", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "That is the real assault. Everything else was noise. They came through the tunnels behind our line. Rotate south, NOW.", voice_style: Normal, portrait: ""),

        // 17: Rear cleared
        (speaker: "Mother Granite", text: "The rear force is broken. Your instinct was correct, otter.", voice_style: Normal, portrait: ""),

        // 18: Time warning
        (speaker: "Deepseek", text: "...fifty ticks remain. Holding.", voice_style: AiVoice, portrait: ""),

        // 19-21: Defense complete
        (speaker: "Mother Granite", text: "The Core Tap holds. The Murder retreats.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Gemineye went quiet when the real force moved. Fabrication AIs cannot stay silent. Someone ordered radio silence manually. That was the Rex.", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "You heard all of that through the fog. Interesting.", voice_style: Normal, portrait: ""),
    ],
    briefing_text: "Defend the Core Tap against Murder incursions. The fog is thick and Gemineye floods detection with phantom contacts. Trust your instincts — the real assault will come from where you least expect.",
    debrief_text: "The Core Tap holds. Mother Granite watched Kelpie filter Gemineye's fabrications in real time. She has questions. Deepseek has concerns.",
    ai_tool_tier: Some(1),
    next_mission: Fixed("act2_m6_triangulation"),
    mutators: [
        DenseFog(
            vision_reduction: 4,
            periodic_clearing: Some((
                interval_ticks: 80,
                clear_duration_ticks: 20,
            )),
        ),
        TimeLimit(
            max_ticks: 600,
            warning_at: 500,
        ),
    ],
)
