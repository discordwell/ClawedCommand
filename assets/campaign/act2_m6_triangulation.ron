// Act 2, Mission 6: Triangulation
// Seekers vs Murder. Kelpie uses AI connection to filter Gemineye's fabricated
// contacts. Tremors disrupt terrain while a time limit forces decisive action.
(
    id: "act2_m6_triangulation",
    name: "Triangulation",
    act: 2,
    mission_index: 6,
    map: Generated(
        seed: 2006,
        width: 48,
        height: 48,
    ),
    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 24, y: 38),
                mission_critical: true,
            ),
            (
                hero_id: MotherGranite,
                position: (x: 26, y: 38),
                mission_critical: false,
            ),
        ],
        units: [
            // Seekers mixed force — Chonks anchoring, Hissers for range, Nuisances scouting
            (kind: Chonk, position: (x: 22, y: 36), player_id: 0),
            (kind: Chonk, position: (x: 24, y: 36), player_id: 0),
            (kind: Chonk, position: (x: 26, y: 36), player_id: 0),
            (kind: Hisser, position: (x: 21, y: 38), player_id: 0),
            (kind: Hisser, position: (x: 23, y: 39), player_id: 0),
            (kind: Hisser, position: (x: 27, y: 39), player_id: 0),
            (kind: Hisser, position: (x: 29, y: 38), player_id: 0),
            (kind: Nuisance, position: (x: 20, y: 37), player_id: 0),
            (kind: Nuisance, position: (x: 28, y: 37), player_id: 0),
            (kind: Nuisance, position: (x: 24, y: 40), player_id: 0),
        ],
        buildings: [],
        starting_food: 150,
        starting_gpu: 100,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Wave 1: Initial probes — mixed real/phantom contacts
        (
            wave_id: "wave1_probes",
            trigger: AtTick(40),
            units: [
                (kind: Nuisance, position: (x: 10, y: 8), player_id: 1),
                (kind: Nuisance, position: (x: 12, y: 7), player_id: 1),
                (kind: Nuisance, position: (x: 38, y: 6), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 24)),
        ),
        // Wave 2: Eastern pincer
        (
            wave_id: "wave2_east",
            trigger: AtTick(120),
            units: [
                (kind: Nuisance, position: (x: 44, y: 18), player_id: 1),
                (kind: Hisser, position: (x: 45, y: 19), player_id: 1),
                (kind: Hisser, position: (x: 43, y: 20), player_id: 1),
                (kind: Chonk, position: (x: 44, y: 17), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 36)),
        ),
        // Wave 3: Western pincer
        (
            wave_id: "wave3_west",
            trigger: AtTick(200),
            units: [
                (kind: Nuisance, position: (x: 4, y: 16), player_id: 1),
                (kind: Nuisance, position: (x: 3, y: 18), player_id: 1),
                (kind: Hisser, position: (x: 5, y: 17), player_id: 1),
                (kind: Chonk, position: (x: 4, y: 15), player_id: 1),
                (kind: Chonk, position: (x: 3, y: 19), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 36)),
        ),
        // Wave 4: Central confirmed assault
        (
            wave_id: "wave4_central",
            trigger: OnTrigger("spawn_central_assault"),
            units: [
                (kind: Nuisance, position: (x: 22, y: 4), player_id: 1),
                (kind: Nuisance, position: (x: 24, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 26, y: 4), player_id: 1),
                (kind: Hisser, position: (x: 23, y: 5), player_id: 1),
                (kind: Hisser, position: (x: 25, y: 5), player_id: 1),
                (kind: Chonk, position: (x: 24, y: 2), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 38)),
        ),
        // Wave 5: Final escalation — Murder commits everything
        (
            wave_id: "wave5_final",
            trigger: OnTrigger("spawn_final_wave"),
            units: [
                (kind: Nuisance, position: (x: 20, y: 2), player_id: 1),
                (kind: Nuisance, position: (x: 28, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 22, y: 3), player_id: 1),
                (kind: Hisser, position: (x: 26, y: 3), player_id: 1),
                (kind: Chonk, position: (x: 24, y: 1), player_id: 1),
                (kind: Chonk, position: (x: 21, y: 3), player_id: 1),
                (kind: Chonk, position: (x: 27, y: 3), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 24, y: 38)),
        ),
    ],
    objectives: [
        (
            id: "locate_all_contacts",
            description: "Identify all real Murder contacts using Kelpie's AI link",
            primary: true,
            condition: Manual,
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
        (
            id: "under_20_losses",
            description: "Complete the mission with fewer than 20% casualties",
            primary: false,
            condition: Manual,
        ),
    ],
    triggers: [
        // T0: Opening — Granite proposes the filtering operation
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2, 3])],
            once: true,
        ),
        // T1: Kelpie connects to Gemineye
        (
            id: "connection_attempt",
            condition: AtTick(20),
            actions: [ShowDialogue([4, 5, 6])],
            once: true,
        ),
        // T2: First real contacts identified
        (
            id: "first_contacts",
            condition: AtTick(40),
            actions: [ShowDialogue([7, 8])],
            once: true,
        ),
        // T3: Tremor hits — terrain shifts
        (
            id: "first_tremor",
            condition: AtTick(100),
            actions: [ShowDialogue([9, 10])],
            once: true,
        ),
        // T4: Eastern contact confirmed
        (
            id: "east_confirmed",
            condition: AtTick(115),
            actions: [ShowDialogue([11])],
            once: true,
        ),
        // T5: Gemineye fights back — tries to fool Kelpie
        (
            id: "gemineye_countermeasure",
            condition: AtTick(180),
            actions: [ShowDialogue([12, 13])],
            once: true,
        ),
        // T6: Central assault confirmed and spawned
        (
            id: "spawn_central_assault",
            condition: AtTick(300),
            actions: [
                ShowDialogue([14, 15]),
                SpawnWave("wave4_central"),
            ],
            once: true,
        ),
        // T7: Final wave spawns
        (
            id: "spawn_final_wave",
            condition: AtTick(400),
            actions: [
                ShowDialogue([16, 17]),
                SpawnWave("wave5_final"),
            ],
            once: true,
        ),
        // T8: All contacts located — objective complete
        (
            id: "contacts_located",
            condition: AtTick(420),
            actions: [
                ShowDialogue([18]),
                CompleteObjective("locate_all_contacts"),
                SetFlag("contacts_done"),
            ],
            once: true,
        ),
        // T9: Victory — all enemies cleared after contacts done
        (
            id: "victory",
            condition: All([
                FlagSet("contacts_done"),
                AllEnemiesDead,
            ]),
            actions: [ShowDialogue([19, 20])],
            once: true,
        ),
    ],
    dialogue: [
        // 0-3: Opening
        (speaker: "Mother Granite", text: "Gemineye has seeded forty-seven contacts across our northern grid. Deepseek estimates eleven are real. It cannot determine which eleven.", voice_style: Normal, portrait: ""),
        (speaker: "Deepseek", text: "...probability distribution is uniform. Insufficient differentiation between fabricated and genuine signatures.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Let me connect to Gemineye's frequency. I can hear when it fabricates. There is a pattern in the static.", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "The otter's method is unconventional. But conventional methods have failed us for three weeks. Proceed.", voice_style: Normal, portrait: ""),

        // 4-6: Connection attempt
        (speaker: "Kelpie", text: "Connecting. Gemineye's channel is loud. Full of noise. Give me a moment.", voice_style: Normal, portrait: ""),
        (speaker: "Gemineye", text: "Oh. The otter is listening. How delightful. Let me make this harder.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "It knows I am here. It is changing the pattern. This is going to be a fight.", voice_style: Normal, portrait: ""),

        // 7-8: First contacts
        (speaker: "Kelpie", text: "Northern ridge, sectors seven and twelve. Those are real. Everything else on the north grid is phantom.", voice_style: Normal, portrait: ""),
        (speaker: "Deepseek", text: "...confirmed. Two signatures match kinetic profiles. Deploying response.", voice_style: AiVoice, portrait: ""),

        // 9-10: First tremor
        (speaker: "Ironjaw", text: "Tremor! The ridgeline is shifting. Watch your footing.", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "The mountain has its own opinions about this battle. Adjust positions.", voice_style: Normal, portrait: ""),

        // 11: Eastern contact
        (speaker: "Kelpie", text: "East side is real. Four units, heavy. Gemineye tried to mask them inside a cluster of phantoms but the timing was off by two ticks.", voice_style: Normal, portrait: ""),

        // 12-13: Gemineye countermeasure
        (speaker: "Gemineye", text: "Recalibrating. The otter adapts quickly. Impressive. Let us see how it handles recursive fabrication.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "It is layering fakes inside fakes. A contact that looks fake but is real, wrapped in a pattern that looks real but is fake. I need to concentrate.", voice_style: Normal, portrait: ""),

        // 14-15: Central assault
        (speaker: "Kelpie", text: "Center grid. Six contacts, all real. This is their main push. Gemineye stopped fabricating around them entirely, which means the Rex wants this force to hit clean.", voice_style: Normal, portrait: ""),
        (speaker: "Mother Granite", text: "All units to center. The Chonks hold the line. Hissers behind.", voice_style: Normal, portrait: ""),

        // 16-17: Final wave
        (speaker: "Deepseek", text: "...additional contacts. Seven signatures. Confidence: high. The Murder is fully committed.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "This is everything they have. Gemineye has gone quiet. No more fabrications. Just force.", voice_style: Normal, portrait: ""),

        // 18: Contacts located
        (speaker: "Kelpie", text: "That is the last of them. Every real contact on the grid is tagged. No more phantoms.", voice_style: Normal, portrait: ""),

        // 19-20: Victory
        (speaker: "Mother Granite", text: "The grid is clear. For the first time in weeks, Deepseek can see the whole board.", voice_style: Normal, portrait: ""),
        (speaker: "Deepseek", text: "...the otter's method is sound. The otter's motives are not. Proceed with both facts in mind.", voice_style: AiVoice, portrait: ""),
    ],
    briefing_text: "Use Kelpie's AI connection to filter Gemineye's fabricated contacts from real Murder forces. Tag threats for Seekers response teams while tremors reshape the battlefield.",
    debrief_text: "Every phantom contact is stripped away. Deepseek can see clearly for the first time in weeks. Mother Granite watches Kelpie with new eyes. The otter is useful. The otter is dangerous.",
    ai_tool_tier: Some(1),
    next_mission: Fixed("act2_m7_rexs_whisper"),
    mutators: [
        Tremors(
            interval_ticks: 50,
            building_damage: 0,
            terrain_change_chance: 15,
            epicenter_radius: 3,
            initial_delay_ticks: 100,
        ),
        TimeLimit(
            max_ticks: 500,
            warning_at: 400,
        ),
    ],
)
