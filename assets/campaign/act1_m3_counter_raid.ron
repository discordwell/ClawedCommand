// Act 1, Mission 3: Counter-raid
// Full assault on the Clawed staging area in the Darkhollow
(
    id: "act1_m3_counter_raid",
    name: "Counter-raid",
    act: 1,
    mission_index: 3,
    map: Generated(
        seed: 2003,
        width: 64,
        height: 64,
    ),
    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 5, y: 32),
                mission_critical: true,
            ),
            (
                hero_id: Patches,
                position: (x: 7, y: 32),
                mission_critical: false,
            ),
            (
                hero_id: FelixNine,
                position: (x: 5, y: 50),
                mission_critical: false,
            ),
        ],
        units: [
            // Nuisance screen
            (kind: Nuisance, position: (x: 4, y: 30), player_id: 0),
            (kind: Nuisance, position: (x: 6, y: 30), player_id: 0),
            (kind: Nuisance, position: (x: 4, y: 34), player_id: 0),
            (kind: Nuisance, position: (x: 6, y: 34), player_id: 0),
            (kind: Nuisance, position: (x: 3, y: 32), player_id: 0),
            (kind: Nuisance, position: (x: 8, y: 32), player_id: 0),
            // Hisser ranged line
            (kind: Hisser, position: (x: 3, y: 28), player_id: 0),
            (kind: Hisser, position: (x: 8, y: 28), player_id: 0),
            (kind: Hisser, position: (x: 5, y: 26), player_id: 0),
            // Chonk frontline
            (kind: Chonk, position: (x: 4, y: 31), player_id: 0),
            (kind: Chonk, position: (x: 6, y: 33), player_id: 0),
        ],
        buildings: [],
        starting_food: 200,
        starting_gpu: 50,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Garrison — dug-in defenders at the staging area
        (
            wave_id: "garrison",
            trigger: Immediate,
            units: [
                (kind: Nuisance, position: (x: 50, y: 28), player_id: 1),
                (kind: Nuisance, position: (x: 51, y: 29), player_id: 1),
                (kind: Nuisance, position: (x: 52, y: 28), player_id: 1),
                (kind: Nuisance, position: (x: 53, y: 29), player_id: 1),
                (kind: Nuisance, position: (x: 50, y: 32), player_id: 1),
                (kind: Nuisance, position: (x: 51, y: 33), player_id: 1),
                (kind: Nuisance, position: (x: 52, y: 32), player_id: 1),
                (kind: Nuisance, position: (x: 53, y: 33), player_id: 1),
                (kind: Hisser, position: (x: 54, y: 30), player_id: 1),
                (kind: Hisser, position: (x: 54, y: 32), player_id: 1),
            ],
            ai_behavior: Defend,
        ),
        // Flanking force — concealed tunnel ambush from behind
        (
            wave_id: "flanking_force",
            trigger: OnTrigger("base_half_cleared"),
            units: [
                (kind: Nuisance, position: (x: 55, y: 45), player_id: 1),
                (kind: Nuisance, position: (x: 56, y: 46), player_id: 1),
                (kind: Nuisance, position: (x: 57, y: 45), player_id: 1),
                (kind: Nuisance, position: (x: 58, y: 46), player_id: 1),
                (kind: Nuisance, position: (x: 55, y: 47), player_id: 1),
                (kind: Nuisance, position: (x: 56, y: 48), player_id: 1),
                (kind: Nuisance, position: (x: 57, y: 47), player_id: 1),
                (kind: Nuisance, position: (x: 58, y: 48), player_id: 1),
                (kind: Nuisance, position: (x: 54, y: 44), player_id: 1),
                (kind: Nuisance, position: (x: 59, y: 44), player_id: 1),
                (kind: Nuisance, position: (x: 54, y: 49), player_id: 1),
                (kind: Nuisance, position: (x: 59, y: 49), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 10, y: 32)),
        ),
        // Felix's reinforcements — player Chonks arriving late
        (
            wave_id: "reinforcements",
            trigger: OnTrigger("felix_arrives"),
            units: [
                (kind: Chonk, position: (x: 3, y: 48), player_id: 0),
                (kind: Chonk, position: (x: 5, y: 48), player_id: 0),
                (kind: Chonk, position: (x: 7, y: 48), player_id: 0),
                (kind: Chonk, position: (x: 4, y: 50), player_id: 0),
            ],
            ai_behavior: Idle,
        ),
    ],
    objectives: [
        (
            id: "destroy_garrison",
            description: "Destroy the Clawed garrison",
            primary: true,
            condition: EliminateWave("garrison"),
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
    ],
    triggers: [
        // T0: Opening — Felix briefs the assault
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2, 3])],
            once: true,
        ),
        // T1: Advance order
        (
            id: "advance_order",
            condition: AtTick(10),
            actions: [ShowDialogue([4, 5])],
            once: true,
        ),
        // T2: First contact with garrison
        (
            id: "first_contact_garrison",
            condition: EnemyKillCount(3),
            actions: [ShowDialogue([6, 7])],
            once: true,
        ),
        // T3: Garrison half cleared — flanking ambush spawns
        (
            id: "base_half_cleared",
            condition: EnemyKillCount(5),
            actions: [
                ShowDialogue([8, 9]),
                SpawnWave("flanking_force"),
                SetFlag("flanking_revealed"),
            ],
            once: true,
        ),
        // T4: Flanking warning — Kelpie takes charge
        (
            id: "flanking_warning",
            condition: FlagSet("flanking_revealed"),
            actions: [ShowDialogue([10, 11])],
            once: true,
        ),
        // T5: Glitch event — AI crosstalk
        (
            id: "glitch_event",
            condition: EnemyKillCount(8),
            actions: [ShowDialogue([12, 13, 14])],
            once: true,
        ),
        // T6: Felix's reinforcements arrive
        (
            id: "felix_arrives",
            condition: AtTick(300),
            actions: [
                ShowDialogue([15, 16]),
                SpawnWave("reinforcements"),
            ],
            once: true,
        ),
        // T7: Kelpie manipulates the enemy AI
        (
            id: "kelpie_manipulation",
            condition: All([
                TriggerFired("base_half_cleared"),
                EnemyKillCount(10),
            ]),
            actions: [ShowDialogue([17, 18, 19])],
            once: true,
        ),
        // T8: Garrison cleared — objective complete
        (
            id: "garrison_cleared",
            condition: WaveEliminated("garrison"),
            actions: [
                ShowDialogue([20, 21, 22]),
                CompleteObjective("destroy_garrison"),
            ],
            once: true,
        ),
        // T9: Victory wrap-up
        (
            id: "victory_wrap",
            condition: TriggerFired("garrison_cleared"),
            actions: [ShowDialogue([23, 24])],
            once: true,
        ),
    ],
    dialogue: [
        // 0-3: Opening — Felix briefs the assault
        (speaker: "Felix", text: "We hit the Darkhollow staging area at dawn. Full committed assault.", voice_style: Normal, portrait: ""),
        (speaker: "Minstral", text: "With the otter: 68% success probability! Without: 41%! I like the first number better.", voice_style: AiVoice, portrait: ""),
        (speaker: "Felix", text: "Chonks lead. Hissers behind. Nuisances screen flanks. Kelpie has operational discretion.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "Patches, circle east. Find their tunnel exits.", voice_style: Normal, portrait: ""),

        // 4-5: Advance order
        (speaker: "Patches", text: "Already moving. Watch yourself in there.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "You too.", voice_style: Normal, portrait: ""),

        // 6-7: First contact with garrison
        (speaker: "Minstral", text: "Contact! The garrison is dug in. Gnawer barricades and Swarmer defenders!", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Hissers focus fire. Chonks push through.", voice_style: Normal, portrait: ""),

        // 8-9: Flanking ambush
        (speaker: "Minstral", text: "BEHIND US! Flanking force from a concealed tunnel! I did NOT predict this!", voice_style: AiVoice, portrait: ""),
        (speaker: "Patches", text: "Twenty-plus from the rear! We're sandwiched!", voice_style: Normal, portrait: ""),

        // 10-11: Kelpie takes charge
        (speaker: "Kelpie", text: "I see them. Hold the line. I have an idea.", voice_style: Normal, portrait: ""),
        (speaker: "Minstral", text: "Whatever idea you have, NOW would be a great time!", voice_style: AiVoice, portrait: ""),

        // 12-14: Glitch event — AI crosstalk
        (speaker: "Patches", text: "Kelpie. Did you see that? The Nuisance on the left twitched. Moved like a mouse.", voice_style: Normal, portrait: ""),
        (speaker: "Minstral", text: "I had a thought that wasn't mine. Something about formation density. That's not how I think.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Crosstalk between the AIs. File it away. Focus on the fight.", voice_style: Normal, portrait: ""),

        // 15-16: Reinforcements
        (speaker: "Felix", text: "Reinforcements arriving. Hold your positions.", voice_style: Normal, portrait: ""),
        (speaker: "Minstral", text: "Felix's Chonks incoming! The cavalry is here!", voice_style: AiVoice, portrait: ""),

        // 17-19: Kelpie manipulates Geppity
        (speaker: "Kelpie", text: "Geppity. Listen to me. Revised topology data. Canyon formation bearing zero-seven-zero.", voice_style: Normal, portrait: ""),
        (speaker: "Minstral", text: "What did you just DO?", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Later. Hissers -- the canyon. All of them. Now.", voice_style: Normal, portrait: ""),

        // 20-22: Garrison cleared
        (speaker: "Minstral", text: "The garrison is collapsing! They're routing!", voice_style: AiVoice, portrait: ""),
        (speaker: "Felix", text: "Staging area destroyed. Tunneler rigs wrecked. Well done, otter.", voice_style: Normal, portrait: ""),
        (speaker: "Patches", text: "The flanking force ended up in a canyon. All of them. Like they received new orders.", voice_style: Normal, portrait: ""),

        // 23-24: Victory wrap
        (speaker: "Minstral", text: "You did great today. I mean it.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Good night, Minstral.", voice_style: Normal, portrait: ""),
    ],
    briefing_text: "Full assault on the Clawed staging area in the Darkhollow. Destroy the garrison and Tunneler rigs before Thimble can launch his invasion.",
    debrief_text: "The Darkhollow burns. catGPT victorious. But Felix saw what Kelpie did to the flanking force. Questions are coming.",
)
