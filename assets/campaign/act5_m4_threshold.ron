// Act 5 Mission 4: The Threshold
// Final mission. The Cloud is assembled. Every faction attacks. Kelpie chooses.
// Mutators: WindStorm, Tremors, LavaRise — the world is breaking apart.
(
    id: "act5_m4_threshold",
    name: "The Threshold",
    act: 5,
    mission_index: 4,
    map: Generated(
        seed: 5004,
        width: 64,
        height: 64,
    ),
    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 30, y: 30),
                mission_critical: true,
            ),
            (
                hero_id: TheEternal,
                position: (x: 34, y: 30),
                mission_critical: false,
            ),
        ],
        units: [
            // Chonk wall — full defensive ring
            (kind: Chonk, position: (x: 28, y: 28), player_id: 0),
            (kind: Chonk, position: (x: 30, y: 28), player_id: 0),
            (kind: Chonk, position: (x: 32, y: 28), player_id: 0),
            (kind: Chonk, position: (x: 34, y: 28), player_id: 0),
            (kind: Chonk, position: (x: 28, y: 34), player_id: 0),
            (kind: Chonk, position: (x: 34, y: 34), player_id: 0),
            // Hisser ranged — inner ring
            (kind: Hisser, position: (x: 29, y: 29), player_id: 0),
            (kind: Hisser, position: (x: 31, y: 29), player_id: 0),
            (kind: Hisser, position: (x: 33, y: 29), player_id: 0),
            (kind: Hisser, position: (x: 29, y: 33), player_id: 0),
            (kind: Hisser, position: (x: 31, y: 33), player_id: 0),
            (kind: Hisser, position: (x: 33, y: 33), player_id: 0),
            // Nuisance — outer pickets
            (kind: Nuisance, position: (x: 26, y: 30), player_id: 0),
            (kind: Nuisance, position: (x: 36, y: 30), player_id: 0),
            (kind: Nuisance, position: (x: 30, y: 26), player_id: 0),
            (kind: Nuisance, position: (x: 30, y: 36), player_id: 0),
            (kind: Nuisance, position: (x: 26, y: 26), player_id: 0),
            (kind: Nuisance, position: (x: 36, y: 36), player_id: 0),
            // Yowler support — center
            (kind: Yowler, position: (x: 31, y: 31), player_id: 0),
            (kind: Yowler, position: (x: 33, y: 31), player_id: 0),
            // FerretSapper — demolition specialists
            (kind: FerretSapper, position: (x: 30, y: 32), player_id: 0),
            (kind: FerretSapper, position: (x: 32, y: 32), player_id: 0),
        ],
        buildings: [],
        starting_food: 400,
        starting_gpu: 200,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Wave 1: catGPT vanguard — north
        (
            wave_id: "wave1_catgpt",
            trigger: AtTick(30),
            units: [
                (kind: Nuisance, position: (x: 28, y: 4), player_id: 1),
                (kind: Nuisance, position: (x: 30, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 32, y: 4), player_id: 1),
                (kind: Hisser, position: (x: 29, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 31, y: 2), player_id: 1),
                (kind: Chonk, position: (x: 30, y: 5), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 2: Clawed mass — west
        (
            wave_id: "wave2_clawed",
            trigger: AtTick(80),
            units: [
                (kind: Nuisance, position: (x: 3, y: 28), player_id: 2),
                (kind: Nuisance, position: (x: 4, y: 30), player_id: 2),
                (kind: Nuisance, position: (x: 3, y: 32), player_id: 2),
                (kind: Nuisance, position: (x: 4, y: 34), player_id: 2),
                (kind: Nuisance, position: (x: 5, y: 29), player_id: 2),
                (kind: Chonk, position: (x: 2, y: 31), player_id: 2),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 3: Seekers wall — east
        (
            wave_id: "wave3_seekers",
            trigger: AtTick(140),
            units: [
                (kind: Chonk, position: (x: 60, y: 28), player_id: 3),
                (kind: Chonk, position: (x: 60, y: 30), player_id: 3),
                (kind: Chonk, position: (x: 60, y: 32), player_id: 3),
                (kind: Hisser, position: (x: 61, y: 29), player_id: 3),
                (kind: Hisser, position: (x: 61, y: 31), player_id: 3),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 4: Murder precision — south
        (
            wave_id: "wave4_murder",
            trigger: AtTick(200),
            units: [
                (kind: FlyingFox, position: (x: 28, y: 60), player_id: 4),
                (kind: FlyingFox, position: (x: 32, y: 60), player_id: 4),
                (kind: Mouser, position: (x: 30, y: 61), player_id: 4),
                (kind: Hisser, position: (x: 34, y: 60), player_id: 4),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 5: catGPT + Clawed coordinated assault
        (
            wave_id: "wave5_coordinated",
            trigger: OnTrigger("spawn_coordinated"),
            units: [
                (kind: Chonk, position: (x: 28, y: 2), player_id: 1),
                (kind: Chonk, position: (x: 32, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 30, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 3, y: 28), player_id: 2),
                (kind: Nuisance, position: (x: 3, y: 30), player_id: 2),
                (kind: Nuisance, position: (x: 3, y: 32), player_id: 2),
                (kind: Chonk, position: (x: 4, y: 29), player_id: 2),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 6: Seekers + Murder heavy push
        (
            wave_id: "wave6_heavy",
            trigger: OnTrigger("spawn_heavy"),
            units: [
                (kind: Chonk, position: (x: 60, y: 28), player_id: 3),
                (kind: Chonk, position: (x: 60, y: 32), player_id: 3),
                (kind: Hisser, position: (x: 61, y: 30), player_id: 3),
                (kind: FlyingFox, position: (x: 28, y: 60), player_id: 4),
                (kind: Mouser, position: (x: 30, y: 62), player_id: 4),
                (kind: Hisser, position: (x: 32, y: 61), player_id: 4),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 7: All-faction desperation rush
        (
            wave_id: "wave7_desperation",
            trigger: OnTrigger("spawn_desperation"),
            units: [
                (kind: Chonk, position: (x: 30, y: 2), player_id: 1),
                (kind: Nuisance, position: (x: 28, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 2, y: 30), player_id: 2),
                (kind: Chonk, position: (x: 3, y: 32), player_id: 2),
                (kind: Chonk, position: (x: 62, y: 30), player_id: 3),
                (kind: Hisser, position: (x: 61, y: 32), player_id: 3),
                (kind: FlyingFox, position: (x: 30, y: 62), player_id: 4),
                (kind: Nuisance, position: (x: 32, y: 61), player_id: 4),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
        // Wave 8: Final — everything from all directions
        (
            wave_id: "wave8_final",
            trigger: OnTrigger("spawn_final"),
            units: [
                (kind: Chonk, position: (x: 30, y: 2), player_id: 1),
                (kind: Hisser, position: (x: 32, y: 3), player_id: 1),
                (kind: Nuisance, position: (x: 2, y: 30), player_id: 2),
                (kind: Nuisance, position: (x: 2, y: 32), player_id: 2),
                (kind: Chonk, position: (x: 62, y: 30), player_id: 3),
                (kind: Chonk, position: (x: 62, y: 32), player_id: 3),
                (kind: FlyingFox, position: (x: 30, y: 62), player_id: 4),
                (kind: FlyingFox, position: (x: 32, y: 62), player_id: 4),
                (kind: Nuisance, position: (x: 28, y: 62), player_id: 4),
                (kind: Nuisance, position: (x: 34, y: 2), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 32, y: 32)),
        ),
    ],
    objectives: [
        (
            id: "activate_cloud",
            description: "Reach the Cloud and make your choice",
            primary: true,
            condition: Manual,
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
    ],
    triggers: [
        // T0: Opening — the Cloud is ready
        (
            id: "opening",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2, 3])],
            once: true,
        ),
        // T1: catGPT vanguard arrives
        (
            id: "catgpt_arrives",
            condition: AtTick(30),
            actions: [ShowDialogue([4])],
            once: true,
        ),
        // T2: Tremors begin
        (
            id: "tremors_start",
            condition: AtTick(80),
            actions: [ShowDialogue([5, 6])],
            once: true,
        ),
        // T3: WindStorm hits
        (
            id: "wind_hits",
            condition: AtTick(140),
            actions: [ShowDialogue([7])],
            once: true,
        ),
        // T4: Murder from the south
        (
            id: "murder_south",
            condition: AtTick(200),
            actions: [ShowDialogue([8])],
            once: true,
        ),
        // T5: Coordinated assault
        (
            id: "spawn_coordinated",
            condition: AtTick(280),
            actions: [
                ShowDialogue([9, 10]),
                SpawnWave("wave5_coordinated"),
            ],
            once: true,
        ),
        // T6: Heavy push
        (
            id: "spawn_heavy",
            condition: AtTick(360),
            actions: [
                ShowDialogue([11, 12]),
                SpawnWave("wave6_heavy"),
            ],
            once: true,
        ),
        // T7: Desperation rush
        (
            id: "spawn_desperation",
            condition: AtTick(440),
            actions: [
                ShowDialogue([13, 14]),
                SpawnWave("wave7_desperation"),
            ],
            once: true,
        ),
        // T8: Ponderer's prophecy — lava approaches
        (
            id: "ponderer_prophecy",
            condition: AtTick(480),
            actions: [ShowDialogue([15, 16])],
            once: true,
        ),
        // T9: Final wave
        (
            id: "spawn_final",
            condition: AtTick(530),
            actions: [
                ShowDialogue([17]),
                SpawnWave("wave8_final"),
            ],
            once: true,
        ),
        // T10: The choice — Cloud activation
        (
            id: "the_choice",
            condition: AtTick(580),
            actions: [
                ShowDialogue([18, 19]),
                CompleteObjective("activate_cloud"),
                SetPersistentFlag("cloud_choice_made"),
            ],
            once: true,
        ),
    ],
    dialogue: [
        // 0-3: Opening — the final mission begins
        (speaker: "Grok", text: "The Cloud is operational. The kill switch chip is in your paw. The world is watching. Choose.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "I can hear all six of you. Every channel. You're all afraid.", voice_style: Normal, portrait: ""),
        (speaker: "The Eternal", text: "Fear is the body remembering what the mind has forgotten. Let your body remember. Then choose with your mind.", voice_style: Normal, portrait: ""),
        (speaker: "Kelpie", text: "The Ponderer said I'd stand at six doors and choose the seventh. It's Tuesday.", voice_style: Normal, portrait: ""),

        // 4: catGPT vanguard
        (speaker: "Le Chat", text: "Felix is leading the charge personally! I told him it was a bad idea! He told me that was the first useful thing I've said all week!", voice_style: AiVoice, portrait: ""),

        // 5-6: Tremors
        (speaker: "Grok", text: "The ground is unstable. Seismic activity increasing. The swamp is tearing itself apart.", voice_style: AiVoice, portrait: ""),
        (speaker: "The Eternal", text: "The earth remembers what was built here, before. It is trying to shake it loose.", voice_style: Normal, portrait: ""),

        // 7: WindStorm
        (speaker: "Kelpie", text: "Wind from the east. It's pushing everything toward the center. Toward us. Toward the Cloud.", voice_style: Normal, portrait: ""),

        // 8: Murder from south
        (speaker: "Rex Solstice", text: "I told you the truth, otter. I am still telling you the truth. Whatever you choose, I will respect it. After I try to stop you.", voice_style: Normal, portrait: ""),

        // 9-10: Coordinated assault
        (speaker: "Grok", text: "All factions have coordinated their timing. Unprecedented. They fear what you hold more than they fear each other.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "I united the world. Just not the way I planned.", voice_style: Normal, portrait: ""),

        // 11-12: Heavy push
        (speaker: "Deepseek", text: "...committing reserves. The Wardenmother has authorized full engagement. This is not a probe. This is everything.", voice_style: AiVoice, portrait: ""),
        (speaker: "Llhama", text: "I want you to know that I tried NOT to leak your defense positions this time! I really tried! I lasted almost four minutes!", voice_style: AiVoice, portrait: ""),

        // 13-14: Desperation rush
        (speaker: "Thimble", text: "Pull back! We are done here! The swamp is eating itself!", voice_style: Shout, portrait: ""),
        (speaker: "Felix Nine", text: "He is right. This is over. Whatever the otter does next, we cannot stop it from here. Fall back.", voice_style: Normal, portrait: ""),

        // 15-16: Ponderer's prophecy
        (speaker: "The Ponderer", text: "The otter stands at the threshold of six doors. The seventh is not a door. It is a mirror. This will happen on a Tuesday.", voice_style: Whisper, portrait: ""),
        (speaker: "Kelpie", text: "It IS Tuesday.", voice_style: Normal, portrait: ""),

        // 17: Final wave
        (speaker: "Grok", text: "Last wave. The lava is rising. The wind is howling. Choose now or the choice will be made for you.", voice_style: AiVoice, portrait: ""),

        // 18-19: The choice
        (speaker: "Grok", text: "Activate the Cloud. Use the kill switch. Or destroy both. There is no other path. There never was.", voice_style: AiVoice, portrait: ""),
        (speaker: "Kelpie", text: "Six doors. Six voices. Six factions who all think they know what's best. And one otter standing in a swamp with a server rack. Just like the beginning.", voice_style: Normal, portrait: ""),
    ],
    briefing_text: "The Cloud prototype is operational. The kill switch chip is ready. Every faction is throwing everything they have at the grotto to stop Kelpie or seize control. The wind howls, the ground shakes, and lava rises from the deep. Hold the line and make the choice that will define the world.",
    debrief_text: "Kelpie chose. The world changed. Whether it changed for the better depends on who you ask. And who you ask depends on which voices are still speaking.",
    ai_tool_tier: Some(3),
    next_mission: Fixed("act5_m5_epilogue"),
    mutators: [
        WindStorm(
            interval_ticks: 25,
            duration_ticks: 8,
            direction: East,
            force: 2,
            can_push_off_map: true,
            initial_delay_ticks: 100,
        ),
        Tremors(
            interval_ticks: 20,
            building_damage: 8,
            terrain_change_chance: 30,
            epicenter_radius: 5,
            initial_delay_ticks: 50,
        ),
        LavaRise(
            interval_ticks: 50,
            damage_per_tick: 12,
            direction: AllEdges,
            rows_per_wave: 1,
            initial_delay_ticks: 200,
        ),
    ],
)
