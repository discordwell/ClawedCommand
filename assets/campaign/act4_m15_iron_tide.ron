        // Wave 2: Ironhide line — Seeker heavy armor push
        (
            wave_id: "wave2_ironhides",
            trigger: AtTick(150),
            units: [
                (kind: Chonk, position: (x: 56, y: 30), player_id: 1),
                (kind: Chonk, position: (x: 57, y: 32), player_id: 1),
                (kind: Chonk, position: (x: 56, y: 34), player_id: 1),
                (kind: Nuisance, position: (x: 55, y: 31), player_id: 1),
