// Act 1, Mission 2: The Dead Drop
// Stealth recon through Darkhollow Woods — locate Clawed staging area
(
    id: "act1_m2_dead_drop",
    name: "The Dead Drop",
    act: 1,
    mission_index: 2,
    map: Generated(
        seed: 2002,
