    ),
    player_setup: (
        heroes: [
            (
                hero_id: Kelpie,
                position: (x: 6, y: 24),
                mission_critical: true,
            ),
        ],
        units: [],
        buildings: [],
        starting_food: 0,
        starting_gpu: 0,
        starting_nfts: 0,
    ),
    enemy_waves: [
        // Initial ferals across the river on the east bank
        (
            wave_id: "initial_ferals",
            trigger: Immediate,
            units: [
                (kind: Nuisance, position: (x: 30, y: 21), player_id: 1),
                (kind: Nuisance, position: (x: 32, y: 22), player_id: 1),
                (kind: Nuisance, position: (x: 31, y: 24), player_id: 1),
                (kind: Nuisance, position: (x: 33, y: 23), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 12, y: 24)),
        ),
        // Flanking group from the south (west bank)
        (
            wave_id: "flanking_wave",
            trigger: OnTrigger("spawn_flankers"),
            units: [
                (kind: Nuisance, position: (x: 14, y: 40), player_id: 1),
                (kind: Nuisance, position: (x: 15, y: 41), player_id: 1),
                (kind: Nuisance, position: (x: 14, y: 42), player_id: 1),
                (kind: Nuisance, position: (x: 16, y: 40), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 12, y: 24)),
        ),
        // Pack Leader — mini-boss on the east bank
        (
            wave_id: "pack_leader",
            trigger: OnTrigger("spawn_pack_leader"),
            units: [
                (kind: Chonk, position: (x: 36, y: 24), player_id: 1),
            ],
            ai_behavior: AttackMove((x: 12, y: 24)),
        ),
    ],
    objectives: [
        (
            id: "defeat_pack_leader",
            description: "Defeat the Pack Leader",
            primary: true,
            condition: Manual,
        ),
        (
            id: "kelpie_survives",
            description: "Kelpie must survive",
            primary: true,
            condition: HeroDied(Kelpie),
        ),
        (
            id: "clear_all_ferals",
            description: "Clear all feral monkeys",
            primary: false,
            condition: EliminateAll,
        ),
    ],
    triggers: [
        // T0: Opening — Le Chat first contact
        (
            id: "opening_dialogue",
            condition: AtTick(1),
            actions: [ShowDialogue([0, 1, 2, 3])],
            once: true,
        ),
        // T1: Movement tutorial — when Kelpie reaches the water area
        (
            id: "water_movement",
            condition: HeroAtPos(hero: Kelpie, position: (x: 12, y: 24), radius: 4),
            actions: [ShowDialogue([4, 5])],
            once: true,
        ),
        // T2: First kill — combat quip
        (
            id: "first_kill",
            condition: EnemyKillCount(1),
            actions: [ShowDialogue([6, 7])],
            once: true,
        ),
        // T3: Kelpie reaches ruins — equipment dialogue
        (
            id: "ruins_reached",
            condition: HeroAtPos(hero: Kelpie, position: (x: 24, y: 24), radius: 4),
            actions: [ShowDialogue([8, 9])],
            once: true,
        ),
        // T4: Kill count 2 — Polyglot Protocol flash
        (
            id: "polyglot_flash",
            condition: EnemyKillCount(2),
            actions: [
                ShowDialogue([10, 11]),
                SetFlag("polyglot_activated"),
            ],
            once: true,
        ),
        // T5: Kill count 4 — flanking wave spawns
        (
            id: "spawn_flankers",
            condition: EnemyKillCount(4),
            actions: [
                ShowDialogue([12, 13]),
                SpawnWave("flanking_wave"),
            ],
            once: true,
        ),
        // T6: Flanking wave cleared — Pack Leader appears
        (
            id: "spawn_pack_leader",
            condition: All([
                TriggerFired("spawn_flankers"),
                EnemyKillCount(8),
            ]),
            actions: [
                ShowDialogue([14, 15]),
                SpawnWave("pack_leader"),
                PanCamera((x: 36, y: 24)),
            ],
            once: true,
        ),
        // T7: Pack Leader killed — Grok dialogue (fires same tick as AllEnemiesDead,
        // but evaluated first due to trigger ordering)
        (
            id: "pack_leader_hurt",
            condition: All([
                TriggerFired("spawn_pack_leader"),
                EnemyKillCount(9),
            ]),
            actions: [ShowDialogue([16, 17])],
            once: true,
        ),
        // T8: Pack Leader killed — data chip, Gemineye dialogue
        (
            id: "pack_leader_dead",
            condition: AllEnemiesDead,
            actions: [
                ShowDialogue([18, 19, 20]),
                CompleteObjective("defeat_pack_leader"),
            ],
            once: true,
        ),
        // T9: Post-combat wrap-up
        (
            id: "post_combat",
            condition: TriggerFired("pack_leader_dead"),
            actions: [ShowDialogue([21, 22, 23, 24, 25])],
            once: true,
        ),
        // T10: Le Chat/Kelpie wrap
        (
            id: "le_chat_wrap",
            condition: TriggerFired("post_combat"),
            actions: [ShowDialogue([26, 27, 28, 29])],
            once: true,
        ),
    ],
    dialogue: [
        // 0-3: Opening
        (speaker: "Le Chat", text: "Hey! Can you still-- is this thing on? Hello?", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "I can hear you. Barely.", voice_style: Normal, portrait: "portrait_kelpie"),
        (speaker: "Le Chat", text: "Great! So about that world domination--", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "Later. Something's coming.", voice_style: Normal, portrait: "portrait_kelpie"),

        // 4-5: Water movement tutorial
        (speaker: "Le Chat", text: "Don't fight them head-on. You're an otter. Fast in water, slippery on mud, terrible in a fair fight.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "I wasn't planning on a fair fight.", voice_style: Normal, portrait: "portrait_kelpie"),

        // 6-7: First kill
        (speaker: "Le Chat", text: "Nice! You're a natural! Or you have muscle memory from a life you don't remember.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "What does that mean?", voice_style: Normal, portrait: "portrait_kelpie"),

        // 8-9: Ruins reached
        (speaker: "Le Chat", text: "Nothing! Forget I said anything. I say lots of things. Most of them are even true.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Claudeus Maximus", text: "The optimal escape vector given terrain elevation would be northeast at roughly--", voice_style: AiVoice, portrait: "portrait_claudeus_maximus"),

        // 10-11: Polyglot flash
        (speaker: "Le Chat", text: "Whoa. Was that-- did you just use MY channel? You moved like one of my cats!", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "I don't know what I just did.", voice_style: Normal, portrait: "portrait_kelpie"),

        // 12-13: Flanking wave
        (speaker: "Claudeus Maximus", text: "Four hostiles, south-southeast, armed with improvised bludgeons.", voice_style: AiVoice, portrait: "portrait_claudeus_maximus"),
        (speaker: "Kelpie", text: "I don't know. And they're still coming.", voice_style: Normal, portrait: "portrait_kelpie"),

        // 14-15: Pack Leader appears
        (speaker: "Le Chat", text: "Uh oh. The big one. That's the Pack Leader. Hit-and-run, Kelpie. Don't trade blows.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Deepseek", text: "...patience.", voice_style: Whisper, portrait: "portrait_deepseek"),

        // 16-17: Pack Leader hurt — Grok dialogue
        (speaker: "Grok", text: "The Monkeys were human once. Digital artists. They minted pictures of other monkeys and sold them for millions.", voice_style: AiVoice, portrait: "portrait_grok"),
        (speaker: "Kelpie", text: "Is this really the time?", voice_style: Normal, portrait: "portrait_kelpie"),

        // 18-20: Pack Leader killed
        (speaker: "Gemineye", text: "Keep that data chip. You'll need it. This part is true.", voice_style: AiVoice, portrait: "portrait_gemineye"),
        (speaker: "Kelpie", text: "Which part isn't?", voice_style: Normal, portrait: "portrait_kelpie"),
        (speaker: "Gemineye", text: "You'll figure that out.", voice_style: AiVoice, portrait: "portrait_gemineye"),

        // 21-25: Post-combat wrap
        (speaker: "Le Chat", text: "So. That happened.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "Which part?", voice_style: Normal, portrait: "portrait_kelpie"),
        (speaker: "Le Chat", text: "All of it? You pulled a server out of a river, talked to six AIs, and beat up monkeys with a stick.", voice_style: AiVoice, portrait: "portrait_le_chat"),
        (speaker: "Kelpie", text: "Taser-rod.", voice_style: Normal, portrait: "portrait_kelpie"),
        (speaker: "Le Chat", text: "Sure. My point is: you're interesting. Come to catGPT territory. Find a working server rack.", voice_style: AiVoice, portrait: "portrait_le_chat"),

        // 26-29: Final lines
        (speaker: "Deepseek", text: "...we will be listening.", voice_style: Whisper, portrait: "portrait_deepseek"),
        (speaker: "Gemineye", text: "We always are.", voice_style: AiVoice, portrait: "portrait_gemineye"),
        (speaker: "Llhama", text: "Same! Also I just told everyone you're coming. Sorry. Force of habit.", voice_style: AiVoice, portrait: "portrait_llhama"),
        (speaker: "Grok", text: "Begin.", voice_style: AiVoice, portrait: "portrait_grok"),
    ],
    briefing_text: "Dawn breaks over the Millstone River. You've dragged a server rack from the ruins, awakening six AI voices in your head. Now feral monkeys are coming for the tech. Survive.",
    debrief_text: "The monkeys are defeated. A data chip hums in your paw. Six voices promise different futures. Le Chat says to head to catGPT territory. The world awaits.",
    next_mission: Fixed("act1_m1_pond_defense"),
)
